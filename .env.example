# Steam Deck Remote Development Configuration
# Copy this file to .env and fill in your actual values

# Steam Deck Connection Settings
DECK_HOST=steamdeck
DECK_USER=deck
DECK_PASSWORD=your_deck_password_here
DECK_PORT=22

# Remote Paths on Steam Deck
DECK_PLUGIN_DIR=/home/deck/homebrew/plugins/deck-charge-scheduler
DECK_SYSTEMD_DIR=/home/deck/.config/systemd/user

# Development Settings
ENABLE_CEF_DEBUGGING=true
CEF_DEBUG_PORT=8081
DECKY_LOADER_URL=http://steamdeck:8081


# Development Options
SKIP_VERIFICATION=false
BACKUP_BEFORE_DEPLOY=true